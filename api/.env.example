# Path to Outplayed media directory (contains game subfolders with .mp4 files)
OUTPLAYED_MEDIA_DIR=C:\Users\YourName\Videos\Outplayed

# Workspace directory for output files (clips, renders)
WORKSPACE_DIR=C:\Users\YourName\Videos\ai_video_editor_output

# Path to ffmpeg binary (optional, defaults to "ffmpeg" assuming it's in PATH)
FFMPEG_PATH=ffmpeg

# --- Phase 2: AI analyzer ---
ANTHROPIC_API_KEY=sk-ant-...
RANKER_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_RANK_CALLS=25

# Riot API source for League kill events (optional; free dev key at
# https://developer.riotgames.com). Leave blank to disable this source.
RIOT_API_KEY=
RIOT_ID=YourName#NA1
RIOT_REGION=americas
# Nudge if Riot clips land consistently early/late (seconds, +/-).
RIOT_SYNC_OFFSET_SECONDS=0.0
# IANA timezone of recording filenames' local timestamps (DST-aware),
# used to correlate to Riot's UTC match times.
RECORDING_TIMEZONE=America/Chicago

# Langfuse tracing (free account at https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Analyzer tuning knobs (optional, sensible defaults in config.py)
ANALYZE_MAX_CANDIDATES=15
ANALYZE_PEAK_THRESHOLD=0.6
ANALYZE_WINDOW_PADDING=4.0
ANALYZE_SCORE_THRESHOLD=0.5

# Local Whisper STT (private, $0). cpu is reliable; set cuda only if
# the CUDA runtime is installed. base=fast; small/medium=better/slower.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Video encoder for /edit/compile (per-clip re-encode). libx264 is the
# portable CPU default. Uncomment for NVIDIA GPU encode (~2-3x faster)
# — requires NVIDIA driver >= 570 (NVENC API 13.0).
# FFMPEG_VIDEO_CODEC=h264_nvenc
# FFMPEG_VIDEO_CODEC_OPTS=-preset p4 -cq 23 -rc vbr

# Highlight clip window around an exact event (Riot kill): seconds of
# lead-up and follow-through. Widen for more context.
HIGHLIGHT_PRE_SECONDS=7.5
HIGHLIGHT_POST_SECONDS=7.5